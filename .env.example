# ─── Database (Supabase PostgreSQL) ──────────────────────────────────────────
#
# Two connection strings are required for Supabase:
#
# DATABASE_URL — PgBouncer pooled connection (port 6543)
#   Used by the application at runtime for all queries.
#   Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
#
# DIRECT_URL — Direct PostgreSQL connection (port 5432)
#   Used by Prisma Migrate for schema migrations (PgBouncer doesn't support DDL).
#   Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
#
# See DATABASE_SETUP.md for step-by-step Supabase setup instructions.

DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ─── Auth (NextAuth.js / Auth.js v5) ────────────────────────────────────────
#
# NEXTAUTH_SECRET — Random secret for JWT encryption. Generate with:
#   openssl rand -base64 32
#
# NEXTAUTH_URL — Canonical URL of your app (no trailing slash).

NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── OAuth Providers ─────────────────────────────────────────────────────────
#
# Google OAuth — Create at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# GitHub OAuth — Create at https://github.com/settings/developers
GITHUB_ID="your-github-client-id"
GITHUB_SECRET="your-github-client-secret"

# ─── Email (Resend - Magic Links) ────────────────────────────────────────────
#
# Resend API key — Get at https://resend.com/api-keys
RESEND_API_KEY="re_your-resend-api-key"
EMAIL_FROM="Flowmind <noreply@flowmind.app>"

# ─── AI (Anthropic) ──────────────────────────────────────────────────────────
#
# ANTHROPIC_API_KEY — API key for Claude models (used for AI capture/parsing)
#   Get at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="sk-ant-your-anthropic-api-key"

# ─── Monitoring (Sentry) ──────────────────────────────────────────────────────
#
# NEXT_PUBLIC_SENTRY_DSN — Sentry Data Source Name for error tracking
#   Get at https://sentry.io → Project Settings → Client Keys (DSN)
#
# SENTRY_AUTH_TOKEN — Required for source map uploads during build
#   Generate at https://sentry.io → Settings → Auth Tokens
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
