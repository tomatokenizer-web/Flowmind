// ─── Proposal (M.2: unified AI write path, 8 kinds) ────────────────

model Proposal {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kind         String    @db.VarChar(30) // reframe, counter, maturation, rule_action, import_merge, compounding, type_suggest, relation_suggest
  targetUnitId String?   @map("target_unit_id") @db.Uuid
  contextId    String?   @map("context_id") @db.Uuid
  userId       String    @map("user_id")
  status       String    @default("pending") @db.VarChar(20) // pending, accepted, rejected, expired
  payload      Json // Kind-specific data
  rationale    String?
  createdAt    DateTime  @default(now()) @map("created_at")
  resolvedAt   DateTime? @map("resolved_at")

  // DEC-2026-002 §B.15.6: monotonically-increasing tick stamped at
  // evaluation time. Rule-scan writes are idempotent per (targetUnitId,
  // rule_key, evalTick) so repeated scans don't duplicate proposals.
  evalTick Int? @map("eval_tick")

  @@index([targetUnitId])
  @@index([contextId])
  @@index([userId, status])
  @@index([kind, status])
  @@index([evalTick])
  @@index([targetUnitId, kind, status])
  @@map("proposals")
}

