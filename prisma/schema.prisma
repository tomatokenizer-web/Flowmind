generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

// ─── User & Auth ────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  accounts      Account[]
  sessions      Session[]
  projects      Project[]
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Projects ───────────────────────────────────────────────────────────────

model Project {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  type            String?         @db.VarChar(50)
  templateId      String?         @map("template_id") @db.Uuid
  constraintLevel String          @default("guided") @map("constraint_level") @db.VarChar(10)
  branchedFrom    String?         @map("branched_from") @db.Uuid
  branchReason    String?         @map("branch_reason")
  userId          String          @map("user_id")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  template        DomainTemplate? @relation(fields: [templateId], references: [id])
  parent          Project?        @relation("ProjectBranch", fields: [branchedFrom], references: [id])
  branches        Project[]       @relation("ProjectBranch")
  units           Unit[]
  contexts        Context[]
  assemblies      Assembly[]
  customRelationTypes CustomRelationType[]

  @@index([userId])
  @@map("projects")
}

// ─── Domain Templates ───────────────────────────────────────────────────────

model DomainTemplate {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  slug      String   @unique @db.VarChar(100)
  type      String   @db.VarChar(30) // system, freeform, user_defined
  config    Json     // types, relations, scaffold_questions, gap_rules, etc.
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  projects  Project[]

  @@map("domain_templates")
}

// ─── Units (Thought Units) ──────────────────────────────────────────────────

model Unit {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  content      String
  originType   String   @default("direct_write") @map("origin_type") @db.VarChar(30)
  lifecycle    String   @default("draft") @db.VarChar(20)
  quality      String   @default("raw") @db.VarChar(20)
  sourceUrl    String?  @map("source_url")
  sourceTitle  String?  @map("source_title")
  isQuote      Boolean  @default(false) @map("is_quote")
  aiTrustLevel String?  @map("ai_trust_level") @db.VarChar(20)
  embedding    Unsupported("vector(1536)")?
  meta         Json?
  projectId    String   @map("project_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")
  modifiedAt   DateTime @updatedAt @map("modified_at")
  lastAccessed DateTime @default(now()) @map("last_accessed")

  project      Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  perspectives UnitPerspective[]
  versions     UnitVersion[]
  assemblyItems AssemblyItem[]
  relationsAsSource Relation[]   @relation("SourceUnit")
  relationsAsTarget Relation[]   @relation("TargetUnit")

  @@index([projectId])
  @@index([lifecycle])
  @@index([createdAt])
  @@map("units")
}

// ─── Perspectives (Context-specific interpretation) ─────────────────────────

model UnitPerspective {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  unitId     String  @map("unit_id") @db.Uuid
  contextId  String  @map("context_id") @db.Uuid
  type       String  @db.VarChar(50) // claim, question, evidence, etc.
  stance     String  @default("neutral") @db.VarChar(20)
  importance Float   @default(0)
  note       String?
  canvasX    Float?  @map("canvas_x")
  canvasY    Float?  @map("canvas_y")
  canvasZoom Float?  @map("canvas_zoom")

  unit       Unit    @relation(fields: [unitId], references: [id], onDelete: Cascade)
  context    Context @relation(fields: [contextId], references: [id], onDelete: Cascade)
  relations  Relation[]

  @@unique([unitId, contextId])
  @@index([contextId])
  @@map("unit_perspectives")
}

// ─── Relations (Directed edges between Units) ───────────────────────────────

model Relation {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sourceUnitId  String   @map("source_unit_id") @db.Uuid
  targetUnitId  String   @map("target_unit_id") @db.Uuid
  perspectiveId String?  @map("perspective_id") @db.Uuid
  type          String   @db.VarChar(50)
  strength      Float    @default(0.5)
  direction     String   @default("one_way") @db.VarChar(15)
  purpose       String[] @default([]) // navigation, argument, context, reference
  isCustom      Boolean  @default(false) @map("is_custom")
  customName    String?  @map("custom_name")
  createdAt     DateTime @default(now()) @map("created_at")

  sourceUnit    Unit            @relation("SourceUnit", fields: [sourceUnitId], references: [id], onDelete: Cascade)
  targetUnit    Unit            @relation("TargetUnit", fields: [targetUnitId], references: [id], onDelete: Cascade)
  perspective   UnitPerspective? @relation(fields: [perspectiveId], references: [id], onDelete: SetNull)

  @@index([sourceUnitId])
  @@index([targetUnitId])
  @@index([type])
  @@map("relations")
}

// ─── System Relation Types (Reference table) ────────────────────────────────

model SystemRelationType {
  id          String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String @unique @db.VarChar(50)
  category    String @db.VarChar(50) // argument, creative_research, structure
  description String
  sortOrder   Int    @map("sort_order")

  @@map("system_relation_types")
}

// ─── Custom Relation Types (User-defined) ───────────────────────────────────

model CustomRelationType {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  projectId String   @map("project_id") @db.Uuid
  scope     String   @default("private") @db.VarChar(10)
  reusable  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("custom_relation_types")
}

// ─── Contexts (Exploration spaces) ──────────────────────────────────────────

model Context {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  projectId      String   @map("project_id") @db.Uuid
  parentId       String?  @map("parent_id") @db.Uuid
  snapshot       Json?
  openQuestions   Json?    @map("open_questions")
  contradictions Json?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  project        Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent         Context?          @relation("ContextHierarchy", fields: [parentId], references: [id])
  children       Context[]         @relation("ContextHierarchy")
  perspectives   UnitPerspective[]
  navigators     Navigator[]

  @@index([projectId])
  @@map("contexts")
}

// ─── Unit Versions (Change history) ─────────────────────────────────────────

model UnitVersion {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  unitId       String   @map("unit_id") @db.Uuid
  version      Int
  content      String
  meta         Json?
  changeReason String?  @map("change_reason")
  diffSummary  String?  @map("diff_summary")
  createdAt    DateTime @default(now()) @map("created_at")

  unit         Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([unitId, version])
  @@index([unitId])
  @@map("unit_versions")
}

// ─── Assemblies (Output documents) ──────────────────────────────────────────

model Assembly {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  projectId    String   @map("project_id") @db.Uuid
  templateType String?  @map("template_type") @db.VarChar(50)
  sourceMap    Json?    @map("source_map")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  project      Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items        AssemblyItem[]

  @@index([projectId])
  @@map("assemblies")
}

model AssemblyItem {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assemblyId String  @map("assembly_id") @db.Uuid
  unitId     String? @map("unit_id") @db.Uuid
  position   Int
  bridgeText String? @map("bridge_text")

  assembly   Assembly @relation(fields: [assemblyId], references: [id], onDelete: Cascade)
  unit       Unit?    @relation(fields: [unitId], references: [id], onDelete: SetNull)

  @@index([assemblyId])
  @@map("assembly_items")
}

// ─── Navigators (Ordered exploration paths) ─────────────────────────────────

model Navigator {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  purpose   String? @db.VarChar(30) // argument, creative, chronological, explore
  contextId String  @map("context_id") @db.Uuid
  path      String[] @default([]) @db.Uuid // ordered Unit IDs

  context   Context @relation(fields: [contextId], references: [id], onDelete: Cascade)

  @@index([contextId])
  @@map("navigators")
}
