generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [uuid_ossp(map: "uuid-ossp"), vector]
}

// ─── Enums (PRD Appendix A) ────────────────────────────────────────

enum UnitType {
  claim
  question
  evidence
  counterargument
  observation
  idea
  definition
  assumption
  action
  interpretation // DEC-004 §G.1 restored
  example // DEC-004 §G.1 restored
  decision // DEC-004 §G.1 restored
}

enum OriginType {
  direct_write
  external_excerpt
  external_inspiration
  external_summary
  ai_generated
  ai_refined
}

enum Lifecycle {
  draft
  pending
  confirmed
  deferred
  complete
  archived
  discarded
  fossilized
  promoted
}

enum Quality {
  raw
  refined
  verified
  published
}

enum EvidenceDomain {
  external_public
  external_private
  personal_event
  personal_belief
  personal_intuition
  reasoned_inference
}

enum Scope {
  universal
  domain_general
  domain_specific
  situational
  interpersonal
  personal
}

enum AiTrustLevel {
  user_authored
  verified
  inferred
  uncertain
}

enum EnergyLevel {
  high
  neutral
  low
}

enum Certainty {
  certain
  probable
  hypothesis
  uncertain
}

enum Completeness {
  complete
  needs_evidence
  unaddressed_counterarg
  exploring
  fragment
}

enum AbstractionLevel {
  principle
  concept
  case_study @map("case")
  detail
}

enum Stance {
  support
  oppose
  neutral
  exploring
}

enum ResourceType {
  image
  table
  audio
  diagram
  link
  video
  code
}

enum VersionOriginType {
  manual
  ai_suggestion
  merge
  split
  import
}

// ─── Phase 0 §0.8 Enums (DEC-004 + v3.14) ─────────────────────────

enum RelationLayer {
  structural
  evidential
  dialogical
  generative
  temporal
  compositional
  analytical
  meta
}

enum RelationSubtype {
  // Layer 1: Argumentative (5)
  supports
  contradicts
  qualifies
  rebuts
  concedes
  // Layer 2: Epistemic Derivation (4, derives_from removed v3.11)
  generalizes
  specializes
  operationalizes
  exemplifies
  // Layer 3: Rhetorical / RST (14)
  elaboration
  cause
  condition
  contrast
  sequence
  purpose
  background
  evaluation
  summary
  restatement
  means
  concession_rst  @map("concession")
  solutionhood
  enablement
  // Layer 4: Semantic / Conceptual (6)
  is_type_of
  is_part_of
  is_instance_of
  contains
  preconditions
  results_in
  // Layer 5: Temporal / Narrative (6, echoes removed v3.11)
  precedes
  follows
  co_occurs
  interrupts
  enables_next
  continues
  // Layer 6: Associative / Heuristic (6)
  related_to
  inspires
  reminds
  parallels
  analogizes
  triggers
  // Layer 7: Meta / Structural (7)
  references
  comments_on
  questions_meta  @map("questions")
  answers
  revises
  supersedes
  branches_from
  // Layer 8: Action / Execution (7)
  requires
  blocks
  depends_on
  implements
  validates
  delegates
  matures_into
}

enum EpistemicAct {
  // Assertive
  assert
  hypothesize
  predict
  // Inquiry
  ask
  challenge
  // Evaluative
  endorse
  critique
  concede
  refute
  // Definitional
  define
  distinguish
  classify
  // Structural
  decompose
  synthesize
  generalize
  specialize
  // Reframing
  reframe
  analogize
  // Metacognitive
  retract
  revise
}

enum LifecycleState {
  draft
  confirmed
  deferred
  archived
}

// DEC-2026-002 §7: salience tier bucketing for attention routing.
// `foreground` = top-decile active items, `background` = stable mid,
// `deep` = cold / archival. Bucketed from salienceScore percentile.
enum SalienceTier {
  foreground
  background
  deep
}

// ─── Phase 0: New field enums (Metadata-Reference v3.14) ──────────

enum UnitKind {
  thought
  resource
  shadow
}

enum Voice {
  original
  ai_assisted
  ai_refined
  ai_sourced
  external
  imported
}

enum TypeConfidence {
  high
  medium
  low
}

enum EpistemicOrigin {
  first_person_experience
  first_person_inference
  received_testimony
  institutional_record
  consensus_knowledge
  formal_derivation
}

enum ApplicabilityScope {
  universal
  domain_universal
  context_conditional
  instance_specific
  personal
}

enum TemporalValidity {
  atemporal
  durable
  current
  time_bounded
  historical
  recurrent
}

enum Revisability {
  immutable
  evidence_revisable
  authority_revisable
  convention_revisable
  personally_revisable
}

enum WarrantCommunity {
  universal_competent
  disciplinary_expert
  institutional
  community_relative
  personal_authority
}

enum CertaintyLevel {
  confirmed_cert @map("confirmed")
  probable
  uncertain
  speculative
}

enum ContextDependency {
  free
  anchored
  passage
}

enum ContextRole {
  seed
  anchor
  bridge
  peripheral
  evergreen_role @map("evergreen")
}

enum RoleSource {
  ai_computed
  user_confirmed
  user_set
}

enum ScaleSource {
  graph_derived
  user_override
}

enum NsDirection {
  nucleus_to_satellite
  satellite_to_nucleus
  multinuclear
}

enum RelationCreatedBy {
  user_created           @map("user")
  ai_suggested_confirmed
  ai_auto
}

enum InquiryStatus {
  exploring
  active
  paused
  completed
  abandoned
}

enum InquiryFormation {
  top_down
  organic
}

enum PursuitStatus {
  active_pursuit    @map("active")
  paused_pursuit    @map("paused")
  completed_pursuit @map("completed")
  archived_pursuit  @map("archived")
}

// ─── Models ────────────────────────────────────────────────────────

model User {
  id                  String               @id @default(cuid())
  name                String?
  email               String?              @unique
  emailVerified       DateTime?            @map("email_verified")
  image               String?
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  /// Whether the user has completed the onboarding flow
  onboardingCompleted Boolean              @default(false) @map("onboarding_completed")
  /// The last onboarding step index the user reached (0-based)
  onboardingStep      Int                  @default(0) @map("onboarding_step")
  accounts            Account[]
  projects            Project[]
  sessions            Session[]
  units               Unit[]
  resources           ResourceUnit[]
  contextVisits       ContextVisit[]
  contextReferences   ContextReference[]
  customRelationTypes CustomRelationType[]
  webhooks            Webhook[]
  exportHistory       ExportHistory[]
  aiUsageLogs         AIUsageLog[]
  decisionJournals    DecisionJournal[]
  projectShares       ProjectShare[]
  sourceGroups        SourceGroup[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Project {
  id                  String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                String
  type                String?              @db.VarChar(50)
  templateId          String?              @map("template_id") @db.Uuid
  constraintLevel     String               @default("guided") @map("constraint_level") @db.VarChar(10)
  branchedFrom        String?              @map("branched_from") @db.Uuid
  branchReason        String?              @map("branch_reason")
  userId              String               @map("user_id")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  assemblies          Assembly[]
  contexts            Context[]
  customRelationTypes CustomRelationType[]
  parent              Project?             @relation("ProjectBranch", fields: [branchedFrom], references: [id])
  branches            Project[]            @relation("ProjectBranch")
  template            DomainTemplate?      @relation(fields: [templateId], references: [id])
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  units               Unit[]
  tags                Tag[]
  webhooks            Webhook[]
  pursuits            Pursuit[]
  shares              ProjectShare[]
  decisionJournals    DecisionJournal[]
  sourceGroups        SourceGroup[]

  @@index([userId])
  @@map("projects")
}

model DomainTemplate {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  slug      String    @unique @db.VarChar(100)
  type      String    @db.VarChar(30)
  config    Json
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  projects  Project[]
  pursuits  Pursuit[]
  inquiries Inquiry[]

  @@map("domain_templates")
}

// ── Source Group: units decomposed from one structured text ─────────────
model SourceGroup {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String   @map("user_id")
  projectId     String   @map("project_id") @db.Uuid
  contextId     String?  @map("context_id") @db.Uuid
  originalText  String   @map("original_text")
  title         String?
  unitCount     Int      @default(0) @map("unit_count")
  createdAt     DateTime @default(now()) @map("created_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  context Context? @relation(fields: [contextId], references: [id], onDelete: SetNull)
  units   Unit[]

  @@index([userId])
  @@index([projectId])
  @@index([contextId])
  @@map("source_groups")
}

model Unit {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  content   String
  userId    String @map("user_id")
  projectId String @map("project_id") @db.Uuid

  // ── EXISTING fields (kept for backward compat, Phase 1 will migrate) ──

  // A-1: Cognitive Classification (LEGACY — v3.14 moves certainty/stance to Perspective)
  unitType         UnitType          @default(claim) @map("unit_type")
  certainty        Certainty?
  completeness     Completeness?
  abstractionLevel AbstractionLevel? @map("abstraction_level")
  stance           Stance?

  // A-3: Status (LEGACY — v3.14 lifecycle is 4-state, quality removed)
  lifecycle      Lifecycle @default(draft)
  quality        Quality   @default(raw)
  actionRequired Boolean   @default(false) @map("action_required")
  flagged        Boolean   @default(false)
  pinned         Boolean   @default(false)
  incubating     Boolean   @default(false)
  locked         Boolean   @default(false)

  // A-4: Temporal
  createdAt       DateTime  @default(now()) @map("created_at")
  modifiedAt      DateTime  @updatedAt @map("modified_at")
  lastAccessed    DateTime  @default(now()) @map("last_accessed")
  capturedAt      DateTime? @map("captured_at")
  validUntil      DateTime? @map("valid_until")
  temporalContext String?   @map("temporal_context")
  recurrence      String?

  // A-5: Provenance (LEGACY — v3.14 uses voice instead of originType)
  originType     OriginType    @default(direct_write) @map("origin_type")
  sourceUrl      String?       @map("source_url")
  sourceTitle    String?       @map("source_title")
  author         String?
  isQuote        Boolean       @default(false) @map("is_quote")
  aiTrustLevel   AiTrustLevel? @map("ai_trust_level")
  conversationId String?       @map("conversation_id")
  parentInputId  String?       @map("parent_input_id")
  sourceSpan     Json?         @map("source_span")

  // A-6: Evidence Character (LEGACY — removed in v3.14)
  evidenceDomain EvidenceDomain? @map("evidence_domain")
  scope          Scope?

  // A-9: AI Analysis
  embedding       Unsupported("vector")?
  importance      Float                  @default(0)
  branchPotential Float                  @default(0) @map("branch_potential")
  driftScore      Float                  @default(0) @map("drift_score")

  // A-10: Ordering
  sortOrder Int? @map("sort_order")

  // A-11: User-defined
  energyLevel EnergyLevel? @map("energy_level")
  meta        Json?

  // ── NEW v3.14 fields (Phase 0 additive) ───────────────────────────

  // Identity
  unitKind             UnitKind  @default(thought) @map("unit_kind")
  sourceText           String?   @map("source_text") // Original wording, never edited
  embeddingModel       String?   @map("embedding_model") // D-11: model tracking
  embeddingGeneratedAt DateTime? @map("embedding_generated_at")

  // Propositional Character (v3.14: 3 attrs on Unit)
  primaryType    UnitType?       @map("primary_type") // Will replace unitType in Phase 1
  secondaryTypes UnitType[]      @default([]) @map("secondary_types")
  typeConfidence TypeConfidence? @map("type_confidence")

  // Epistemic Act
  primaryEpistemicAct    EpistemicAct?  @map("primary_epistemic_act")
  secondaryEpistemicActs EpistemicAct[] @default([]) @map("secondary_epistemic_acts")

  // Knowledge Context
  epistemicOrigin        EpistemicOrigin?    @map("epistemic_origin")
  applicabilityScope     ApplicabilityScope? @map("applicability_scope")
  temporalValidity       TemporalValidity?   @map("temporal_validity")
  revisability           Revisability?
  warrantCommunity       WarrantCommunity?   @map("warrant_community")
  stalenessAfter         String?             @map("staleness_after")
  falsificationCondition String?             @map("falsification_condition")
  recurrencePeriod       String?             @map("recurrence_period")

  // Status (v3.14)
  lifecycleState    LifecycleState? @map("lifecycle_state") // Will replace lifecycle in Phase 1
  aiReviewPending   Boolean         @default(false) @map("ai_review_pending")
  localOnly         Boolean         @default(false) @map("local_only")
  evergreenUnit     Boolean         @default(false) @map("evergreen")
  controversialFlag Boolean         @default(false) @map("controversial_flag")

  // Provenance (v3.14)
  voice      Voice? // Replaces originType in Phase 1
  authoredBy String? @map("authored_by")

  // Source Group: structured discourse origin
  sourceGroupId  String?  @map("source_group_id") @db.Uuid
  orderInSource  Int?     @map("order_in_source")
  discourseRole  String?  @map("discourse_role") @db.VarChar(500)
  sourceGroup    SourceGroup? @relation(fields: [sourceGroupId], references: [id], onDelete: SetNull)

  // AI Analysis (v3.14: reduced to 5)
  readabilityScore Float?  @map("readability_score")
  language         String? @db.VarChar(10)
  similarUnits     Json?   @map("similar_units") // Cache: [{unit_id, similarity_score}]
  subElements      Json?   @map("sub_elements") // [{text, type}]

  // DEC-2026-002 §7: Cached salience for attention views. salienceScore
  // is a raw 0-1 composite; salienceTier is its bucketed percentile.
  salienceScore     Float?        @map("salience_score")
  salienceTier      SalienceTier? @map("salience_tier")
  salienceUpdatedAt DateTime?     @map("salience_updated_at")

  // Relations
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  project           Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assemblyItems     AssemblyItem[]
  relationsAsSource Relation[]        @relation("SourceUnit")
  relationsAsTarget Relation[]        @relation("TargetUnit")
  perspectives      UnitPerspective[]
  versions          UnitVersion[]
  resources         UnitResource[]
  unitContexts      UnitContext[]
  contextVisits     ContextVisit[]
  unitTags          UnitTag[]
  compassStates     CompassState[]

  @@index([userId])
  @@index([projectId])
  @@index([lifecycle])
  @@index([unitType])
  @@index([createdAt])
  @@index([unitKind])
  @@index([lifecycleState])
  @@index([primaryType])
  @@index([primaryEpistemicAct])
  @@index([salienceTier])
  @@index([incubating])
  @@index([salienceScore])
  @@index([sourceGroupId])
  @@map("units")
}

model UnitPerspective {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  unitId    String @map("unit_id") @db.Uuid
  contextId String @map("context_id") @db.Uuid

  // Existing fields (kept)
  type       UnitType?
  stance     Stance    @default(neutral)
  importance Float     @default(0.5)
  note       String?
  canvasX    Float?    @map("canvas_x")
  canvasY    Float?    @map("canvas_y")
  canvasZoom Float?    @map("canvas_zoom")

  // NEW v3.14 Perspective Layer fields (D-01 expansion)
  certaintyLevel    CertaintyLevel?    @map("certainty_level") // Moved from Unit (v3.11)
  cognitiveScale    Float?             @map("cognitive_scale") // 0.0-10.0, graph-derived per-Context
  scaleSource       ScaleSource?       @map("scale_source")
  contextDependency ContextDependency? @map("context_dependency")
  contextRole       ContextRole?       @map("context_role")
  roleSource        RoleSource?        @map("role_source")

  // Relations
  relations Relation[]
  context   Context    @relation(fields: [contextId], references: [id], onDelete: Cascade)
  unit      Unit       @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([unitId, contextId])
  @@index([contextId])
  @@map("unit_perspectives")
}

model Relation {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sourceUnitId  String   @map("source_unit_id") @db.Uuid
  targetUnitId  String   @map("target_unit_id") @db.Uuid
  perspectiveId String?  @map("perspective_id") @db.Uuid
  type          String   @db.VarChar(50)
  strength      Float    @default(0.5)
  direction     String   @default("one_way") @db.VarChar(15)
  purpose       String[] @default([])
  isCustom      Boolean  @default(false) @map("is_custom")
  customName    String?  @map("custom_name")
  isLoopback    Boolean  @default(false) @map("is_loopback")
  createdAt     DateTime @default(now()) @map("created_at")

  // NEW v3.14 fields (D-05 expansion)
  layer             RelationLayer? // 2-tier: layer determines group
  subtype           RelationSubtype? // Nullable typed subtype within layer
  fromType          String?            @map("from_type") @db.VarChar(50) // D-03: which type aspect relation originates from
  nsDirection       NsDirection?       @map("ns_direction") // Nucleus-Satellite direction
  relationCreatedBy RelationCreatedBy? @map("relation_created_by") // Who created this
  confidence        String?            @db.VarChar(10) // high/medium/low

  // Relations
  perspective UnitPerspective? @relation(fields: [perspectiveId], references: [id])
  sourceUnit  Unit             @relation("SourceUnit", fields: [sourceUnitId], references: [id], onDelete: Cascade)
  targetUnit  Unit             @relation("TargetUnit", fields: [targetUnitId], references: [id], onDelete: Cascade)

  @@index([sourceUnitId])
  @@index([targetUnitId])
  @@index([type])
  @@index([layer])
  @@index([sourceUnitId, targetUnitId, type])
  @@map("relations")
}

model SystemRelationType {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String  @unique @db.VarChar(50)
  category    String  @db.VarChar(50)
  description String
  sortOrder   Int     @map("sort_order")
  // NEW v3.14 fields
  layer       Int? // Layer number (1-8)
  defaultNs   String? @map("default_ns") @db.VarChar(30) // Default NsDirection
  uiTier      Int?    @map("ui_tier") // 1=always visible, 2=accessible, 3=expert

  @@map("system_relation_types")
}

model CustomRelationType {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String   @default("")
  projectId   String   @map("project_id") @db.Uuid
  createdById String?  @map("created_by_id")
  scope       String   @default("private") @db.VarChar(10)
  reusable    Boolean  @default(false)
  purposeTag  String?  @map("purpose_tag")
  createdAt   DateTime @default(now()) @map("created_at")
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy   User?    @relation(fields: [createdById], references: [id])

  @@index([projectId])
  @@index([createdById])
  @@map("custom_relation_types")
}

model Context {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  description    String?
  projectId      String   @map("project_id") @db.Uuid
  parentId       String?  @map("parent_id") @db.Uuid
  snapshot       String   @default("")
  openQuestions  Json     @default("[]") @map("open_questions")
  contradictions Json     @default("[]")
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // NEW v3.14: Inquiry + Pursuit FKs (D-09, nullable)
  inquiryId String? @map("inquiry_id") @db.Uuid
  pursuitId String? @map("pursuit_id") @db.Uuid

  parent           Context?           @relation("ContextHierarchy", fields: [parentId], references: [id])
  children         Context[]          @relation("ContextHierarchy")
  project          Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  inquiry          Inquiry?           @relation("InquiryContexts", fields: [inquiryId], references: [id])
  pursuit          Pursuit?           @relation("PursuitContexts", fields: [pursuitId], references: [id])
  navigators       Navigator[]
  perspectives     UnitPerspective[]
  unitContexts     UnitContext[]
  contextVisits    ContextVisit[]
  sourceReferences ContextReference[] @relation("SourceReferences")
  targetReferences ContextReference[] @relation("TargetReferences")
  reasoningChains  ReasoningChain[]
  sourceGroups     SourceGroup[]

  @@unique([name, parentId, projectId])
  @@index([projectId])
  @@index([parentId])
  @@index([inquiryId])
  @@index([pursuitId])
  @@map("contexts")
}

model UnitContext {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  unitId     String   @map("unit_id") @db.Uuid
  contextId  String   @map("context_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at")
  unit       Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  context    Context  @relation(fields: [contextId], references: [id], onDelete: Cascade)

  @@unique([unitId, contextId])
  @@index([unitId])
  @@index([contextId])
  @@map("unit_contexts")
}

model ContextVisit {
  id               String   @id @default(cuid())
  userId           String   @map("user_id")
  contextId        String   @map("context_id") @db.Uuid
  lastVisitedAt    DateTime @default(now()) @map("last_visited_at")
  lastViewedUnitId String?  @map("last_viewed_unit_id") @db.Uuid
  updatedAt        DateTime @updatedAt @map("updated_at")
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  context          Context  @relation(fields: [contextId], references: [id], onDelete: Cascade)
  lastViewedUnit   Unit?    @relation(fields: [lastViewedUnitId], references: [id], onDelete: SetNull)

  @@unique([userId, contextId])
  @@index([userId])
  @@index([contextId])
  @@map("context_visits")
}

model UnitVersion {
  id            String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  unitId        String             @map("unit_id") @db.Uuid
  version       Int
  content       String
  meta          Json?
  changeReason  String?            @map("change_reason")
  diffSummary   String?            @map("diff_summary")
  /// How this version was produced (manual edit, AI suggestion, merge, split, or import)
  versionOrigin VersionOriginType? @default(manual) @map("version_origin")
  /// Optional reference to the source range this version was derived from
  /// (e.g. character offsets within a source document, or a split-source unit ID)
  sourceSpan    String?            @map("source_span")
  createdAt     DateTime           @default(now()) @map("created_at")
  unit          Unit               @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([unitId, version])
  @@index([unitId])
  @@map("unit_versions")
}

model Assembly {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  projectId     String          @map("project_id") @db.Uuid
  templateType  String?         @map("template_type") @db.VarChar(50)
  sourceMap     Json?           @map("source_map")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  project       Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items         AssemblyItem[]
  exportHistory ExportHistory[]

  @@index([projectId])
  @@map("assemblies")
}

model AssemblyItem {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assemblyId String   @map("assembly_id") @db.Uuid
  unitId     String?  @map("unit_id") @db.Uuid
  position   Int
  bridgeText String?  @map("bridge_text")
  assembly   Assembly @relation(fields: [assemblyId], references: [id], onDelete: Cascade)
  unit       Unit?    @relation(fields: [unitId], references: [id], onDelete: SetNull)

  @@index([assemblyId])
  @@index([unitId])
  @@map("assembly_items")
}

enum PathType {
  // Group A — Logical / Argumentative
  argument
  trace_back
  contradiction_map
  synthesis_first
  toulmin_validation

  // Group B — Exploratory / Generative
  discovery
  question_anchored
  branch_explorer
  socratic
  gap_focused

  // Group C — Analytical / Structural
  causal_chain
  evidence_gradient
  uncertainty_gradient
  conceptual_depth
  stakeholder_perspective
  problem_solution

  // Group D — Connective / Cross-Context
  cross_context
  historical_evolution
  analogy_bridge
  serendipity
}

model Navigator {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String?
  purpose     String?   @db.VarChar(30)
  pathType    PathType? @map("path_type")
  contextId   String    @map("context_id") @db.Uuid
  path        String[]  @default([]) @db.Uuid
  steps       Json      @default("[]") // Array of { unitId, position, annotation? }
  bridges     Json      @default("[]")
  metadata    Json? // Type-specific config (e.g., entry point, reading mode)
  aiGenerated Boolean   @default(false) @map("ai_generated")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")
  context     Context   @relation(fields: [contextId], references: [id], onDelete: Cascade)

  @@index([contextId])
  @@index([pathType])
  @@map("navigators")
}

model ResourceUnit {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  resourceType ResourceType   @map("resource_type")
  url          String
  fileName     String?        @map("file_name")
  mimeType     String?        @map("mime_type")
  fileSize     Int?           @map("file_size")
