generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [uuid_ossp(map: "uuid-ossp", schema: "extensions"), vector]
}

// ─── Enums (PRD Appendix A) ────────────────────────────────────────

enum UnitType {
  claim
  question
  evidence
  counterargument
  observation
  idea
  definition
  assumption
  action
}

enum OriginType {
  direct_write
  external_excerpt
  external_inspiration
  external_summary
  ai_generated
  ai_refined
}

enum Lifecycle {
  draft
  pending
  confirmed
  deferred
  complete
  archived
  discarded
}

enum Quality {
  raw
  refined
  verified
  published
}

enum EvidenceDomain {
  external_public
  external_private
  personal_event
  personal_belief
  personal_intuition
  reasoned_inference
}

enum Scope {
  universal
  domain_general
  domain_specific
  situational
  interpersonal
  personal
}

enum AiTrustLevel {
  user_authored
  verified
  inferred
  uncertain
}

enum EnergyLevel {
  high
  neutral
  low
}

enum Certainty {
  certain
  probable
  hypothesis
  uncertain
}

enum Completeness {
  complete
  needs_evidence
  unaddressed_counterarg
  exploring
  fragment
}

enum AbstractionLevel {
  principle
  concept
  case_study @map("case")
  detail
}

enum Stance {
  support
  oppose
  neutral
  exploring
}

// ─── Models ────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  accounts      Account[]
  projects      Project[]
  sessions      Session[]
  units         Unit[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Project {
  id                  String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                String
  type                String?              @db.VarChar(50)
  templateId          String?              @map("template_id") @db.Uuid
  constraintLevel     String               @default("guided") @map("constraint_level") @db.VarChar(10)
  branchedFrom        String?              @map("branched_from") @db.Uuid
  branchReason        String?              @map("branch_reason")
  userId              String               @map("user_id")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  assemblies          Assembly[]
  contexts            Context[]
  customRelationTypes CustomRelationType[]
  parent              Project?             @relation("ProjectBranch", fields: [branchedFrom], references: [id])
  branches            Project[]            @relation("ProjectBranch")
  template            DomainTemplate?      @relation(fields: [templateId], references: [id])
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  units               Unit[]

  @@index([userId])
  @@map("projects")
}

model DomainTemplate {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  slug      String    @unique @db.VarChar(100)
  type      String    @db.VarChar(30)
  config    Json
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  projects  Project[]

  @@map("domain_templates")
}

model Unit {
  id                String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  content           String
  userId            String                 @map("user_id")
  projectId         String                 @map("project_id") @db.Uuid

  // A-1: Cognitive Classification
  unitType          UnitType               @default(claim) @map("unit_type")
  certainty         Certainty?
  completeness      Completeness?
  abstractionLevel  AbstractionLevel?      @map("abstraction_level")
  stance            Stance?

  // A-3: Status
  lifecycle         Lifecycle              @default(draft)
  quality           Quality                @default(raw)
  actionRequired    Boolean                @default(false) @map("action_required")
  flagged           Boolean                @default(false)
  pinned            Boolean                @default(false)
  incubating        Boolean                @default(false)
  locked            Boolean                @default(false)

  // A-4: Temporal
  createdAt         DateTime               @default(now()) @map("created_at")
  modifiedAt        DateTime               @updatedAt @map("modified_at")
  lastAccessed      DateTime               @default(now()) @map("last_accessed")
  capturedAt        DateTime?              @map("captured_at")
  validUntil        DateTime?              @map("valid_until")
  temporalContext   String?                @map("temporal_context")
  recurrence        String?

  // A-5: Provenance
  originType        OriginType             @default(direct_write) @map("origin_type")
  sourceUrl         String?                @map("source_url")
  sourceTitle       String?                @map("source_title")
  author            String?
  isQuote           Boolean                @default(false) @map("is_quote")
  aiTrustLevel      AiTrustLevel?          @map("ai_trust_level")
  conversationId    String?                @map("conversation_id")
  parentInputId     String?                @map("parent_input_id")
  sourceSpan        Json?                  @map("source_span")

  // A-6: Evidence Character
  evidenceDomain    EvidenceDomain?        @map("evidence_domain")
  scope             Scope?

  // A-9: AI Analysis
  embedding         Unsupported("vector")?
  importance        Float                  @default(0)
  branchPotential   Float                  @default(0) @map("branch_potential")
  driftScore        Float                  @default(0) @map("drift_score")

  // A-11: User-defined
  energyLevel       EnergyLevel?           @map("energy_level")
  meta              Json?

  // Relations
  user              User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  project           Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assemblyItems     AssemblyItem[]
  relationsAsSource Relation[]             @relation("SourceUnit")
  relationsAsTarget Relation[]             @relation("TargetUnit")
  perspectives      UnitPerspective[]
  versions          UnitVersion[]

  @@index([userId])
  @@index([projectId])
  @@index([lifecycle])
  @@index([unitType])
  @@index([createdAt])
  @@map("units")
}

model UnitPerspective {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  unitId     String     @map("unit_id") @db.Uuid
  contextId  String     @map("context_id") @db.Uuid
  type       UnitType
  stance     Stance     @default(neutral)
  importance Float      @default(0)
  note       String?
  canvasX    Float?     @map("canvas_x")
  canvasY    Float?     @map("canvas_y")
  canvasZoom Float?     @map("canvas_zoom")
  relations  Relation[]
  context    Context    @relation(fields: [contextId], references: [id], onDelete: Cascade)
  unit       Unit       @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([unitId, contextId])
  @@index([contextId])
  @@map("unit_perspectives")
}

model Relation {
  id            String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sourceUnitId  String           @map("source_unit_id") @db.Uuid
  targetUnitId  String           @map("target_unit_id") @db.Uuid
  perspectiveId String?          @map("perspective_id") @db.Uuid
  type          String           @db.VarChar(50)
  strength      Float            @default(0.5)
  direction     String           @default("one_way") @db.VarChar(15)
  purpose       String[]         @default([])
  isCustom      Boolean          @default(false) @map("is_custom")
  customName    String?          @map("custom_name")
  createdAt     DateTime         @default(now()) @map("created_at")
  perspective   UnitPerspective? @relation(fields: [perspectiveId], references: [id])
  sourceUnit    Unit             @relation("SourceUnit", fields: [sourceUnitId], references: [id], onDelete: Cascade)
  targetUnit    Unit             @relation("TargetUnit", fields: [targetUnitId], references: [id], onDelete: Cascade)

  @@index([sourceUnitId])
  @@index([targetUnitId])
  @@index([type])
  @@map("relations")
}

model SystemRelationType {
  id          String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String @unique @db.VarChar(50)
  category    String @db.VarChar(50)
  description String
  sortOrder   Int    @map("sort_order")

  @@map("system_relation_types")
}

model CustomRelationType {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  projectId String   @map("project_id") @db.Uuid
  scope     String   @default("private") @db.VarChar(10)
  reusable  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("custom_relation_types")
}

model Context {
  id             String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  projectId      String            @map("project_id") @db.Uuid
  parentId       String?           @map("parent_id") @db.Uuid
  snapshot       Json?
  openQuestions  Json?             @map("open_questions")
  contradictions Json?
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  parent         Context?          @relation("ContextHierarchy", fields: [parentId], references: [id])
  children       Context[]         @relation("ContextHierarchy")
  project        Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  navigators     Navigator[]
  perspectives   UnitPerspective[]

  @@index([projectId])
  @@map("contexts")
}

model UnitVersion {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  unitId       String   @map("unit_id") @db.Uuid
  version      Int
  content      String
  meta         Json?
  changeReason String?  @map("change_reason")
  diffSummary  String?  @map("diff_summary")
  createdAt    DateTime @default(now()) @map("created_at")
  unit         Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([unitId, version])
  @@index([unitId])
  @@map("unit_versions")
}

model Assembly {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  projectId    String         @map("project_id") @db.Uuid
  templateType String?        @map("template_type") @db.VarChar(50)
  sourceMap    Json?          @map("source_map")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  project      Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items        AssemblyItem[]

  @@index([projectId])
  @@map("assemblies")
}

model AssemblyItem {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assemblyId String   @map("assembly_id") @db.Uuid
  unitId     String?  @map("unit_id") @db.Uuid
  position   Int
  bridgeText String?  @map("bridge_text")
  assembly   Assembly @relation(fields: [assemblyId], references: [id], onDelete: Cascade)
  unit       Unit?    @relation(fields: [unitId], references: [id])

  @@index([assemblyId])
  @@map("assembly_items")
}

model Navigator {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  purpose   String?  @db.VarChar(30)
  contextId String   @map("context_id") @db.Uuid
  path      String[] @default([]) @db.Uuid
  context   Context  @relation(fields: [contextId], references: [id], onDelete: Cascade)

  @@index([contextId])
  @@map("navigators")
}
