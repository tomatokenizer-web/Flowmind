// ─── DEC-2026-002 §8: Proactive suppression / cooldown ──────────────
//
// When a user rejects a proactive proposal (surfaced via Proposal with
// kind in {reframe, counter, maturation, compounding, rule_action}),
// the scheduler records a suppression so the same kind+target isn't
// re-surfaced for `expiresAt - now` (typically 7 days). A NULL
// targetUnitId suppresses the entire kind for the user (broader
// "not interested" signal).

model ProactiveSuppression {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @map("user_id")
  proposalKind String   @map("proposal_kind") @db.VarChar(30)
  targetUnitId String?  @map("target_unit_id") @db.Uuid
  reason       String?  @db.VarChar(100) // "user_rejected" | "out_of_budget" | "duplicate"
  createdAt    DateTime @default(now()) @map("created_at")
  expiresAt    DateTime @map("expires_at")

  @@index([userId, expiresAt])
  @@index([userId, proposalKind, targetUnitId])
  @@map("proactive_suppressions")
}

// ─── DEC-2026-002 §19: Compounding acceptance metrics ───────────────
//
// Tracks per-user compounding proposal outcomes so the generator can
// auto-disable itself when acceptance drops below 20% over a 10-window
// rolling sample. Reactivation is opt-in (user must re-enable via
// settings, recorded via `reactivatedAt`). One row per user.

model UserInsightMetrics {
  id                       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                   String    @unique @map("user_id")
  compoundingAccepted      Int       @default(0) @map("compounding_accepted")
  compoundingRejected      Int       @default(0) @map("compounding_rejected")
  compoundingWindow        Json      @default("[]") @map("compounding_window") // last 10 outcomes: ["accepted"|"rejected"|"expired"]
  compoundingDisabledAt    DateTime? @map("compounding_disabled_at")
  compoundingReactivatedAt DateTime? @map("compounding_reactivated_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  @@map("user_insight_metrics")
}

// ─── DEC-2026-002 §10: Epistemic rule conflicts ─────────────────────
//
// When two epistemic rules fire contradictory recommendations on the
// same unit (e.g., "this claim needs evidence" vs "this claim is an
// axiom"), we log the pair for user resolution rather than silently
// picking a winner. Status is `open` until the user accepts one side
// or marks the conflict as tolerated.

model EpistemicConflict {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String    @map("user_id")
  targetUnitId String    @map("target_unit_id") @db.Uuid
  ruleKeyA     String    @map("rule_key_a") @db.VarChar(80)
  ruleKeyB     String    @map("rule_key_b") @db.VarChar(80)
  payloadA     Json      @map("payload_a")
  payloadB     Json      @map("payload_b")
  status       String    @default("open") @db.VarChar(20) // open | resolved_a | resolved_b | tolerated
  resolvedAt   DateTime? @map("resolved_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([userId, status])
  @@index([targetUnitId])
  @@map("epistemic_conflicts")
}
