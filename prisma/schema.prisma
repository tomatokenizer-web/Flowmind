generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [uuid_ossp(map: "uuid-ossp", schema: "extensions"), vector]
}

// ─── Enums (PRD Appendix A) ────────────────────────────────────────

enum UnitType {
  claim
  question
  evidence
  counterargument
  observation
  idea
  definition
  assumption
  action
}

enum OriginType {
  direct_write
  external_excerpt
  external_inspiration
  external_summary
  ai_generated
  ai_refined
}

enum Lifecycle {
  draft
  pending
  confirmed
  deferred
  complete
  archived
  discarded
}

enum Quality {
  raw
  refined
  verified
  published
}

enum EvidenceDomain {
  external_public
  external_private
  personal_event
  personal_belief
  personal_intuition
  reasoned_inference
}

enum Scope {
  universal
  domain_general
  domain_specific
  situational
  interpersonal
  personal
}

enum AiTrustLevel {
  user_authored
  verified
  inferred
  uncertain
}

enum EnergyLevel {
  high
  neutral
  low
}

enum Certainty {
  certain
  probable
  hypothesis
  uncertain
}

enum Completeness {
  complete
  needs_evidence
  unaddressed_counterarg
  exploring
  fragment
}

enum AbstractionLevel {
  principle
  concept
  case_study @map("case")
  detail
}

enum Stance {
  support
  oppose
  neutral
  exploring
}

enum ResourceType {
  image
  table
  audio
  diagram
  link
  video
  code
}

enum VersionOriginType {
  manual
  ai_suggestion
  merge
  split
  import
}

// ─── Models ────────────────────────────────────────────────────────

model User {
  id                   String    @id @default(cuid())
  name                 String?
  email                String?   @unique
  emailVerified        DateTime? @map("email_verified")
  image                String?
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  /// Whether the user has completed the onboarding flow
  onboardingCompleted  Boolean   @default(false) @map("onboarding_completed")
  /// The last onboarding step index the user reached (0-based)
  onboardingStep       Int       @default(0) @map("onboarding_step")
  accounts             Account[]
  projects             Project[]
  sessions             Session[]
  units                Unit[]
  resources            ResourceUnit[]
  contextVisits          ContextVisit[]
  contextReferences      ContextReference[]
  customRelationTypes    CustomRelationType[]
  webhooks               Webhook[]
  exportHistory          ExportHistory[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Project {
  id                  String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                String
  type                String?              @db.VarChar(50)
  templateId          String?              @map("template_id") @db.Uuid
  constraintLevel     String               @default("guided") @map("constraint_level") @db.VarChar(10)
  branchedFrom        String?              @map("branched_from") @db.Uuid
  branchReason        String?              @map("branch_reason")
  userId              String               @map("user_id")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  assemblies          Assembly[]
  contexts            Context[]
  customRelationTypes CustomRelationType[]
  parent              Project?             @relation("ProjectBranch", fields: [branchedFrom], references: [id])
  branches            Project[]            @relation("ProjectBranch")
  template            DomainTemplate?      @relation(fields: [templateId], references: [id])
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  units               Unit[]
  tags                Tag[]
  webhooks            Webhook[]

  @@index([userId])
  @@map("projects")
}

model DomainTemplate {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  slug      String    @unique @db.VarChar(100)
  type      String    @db.VarChar(30)
  config    Json
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  projects  Project[]

  @@map("domain_templates")
}

model Unit {
  id                String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  content           String
  userId            String                 @map("user_id")
  projectId         String                 @map("project_id") @db.Uuid

  // A-1: Cognitive Classification
  unitType          UnitType               @default(claim) @map("unit_type")
  certainty         Certainty?
  completeness      Completeness?
  abstractionLevel  AbstractionLevel?      @map("abstraction_level")
  stance            Stance?

  // A-3: Status
  lifecycle         Lifecycle              @default(draft)
  quality           Quality                @default(raw)
  actionRequired    Boolean                @default(false) @map("action_required")
  flagged           Boolean                @default(false)
  pinned            Boolean                @default(false)
  incubating        Boolean                @default(false)
  locked            Boolean                @default(false)

  // A-4: Temporal
  createdAt         DateTime               @default(now()) @map("created_at")
  modifiedAt        DateTime               @updatedAt @map("modified_at")
  lastAccessed      DateTime               @default(now()) @map("last_accessed")
  capturedAt        DateTime?              @map("captured_at")
  validUntil        DateTime?              @map("valid_until")
  temporalContext   String?                @map("temporal_context")
  recurrence        String?

  // A-5: Provenance
  originType        OriginType             @default(direct_write) @map("origin_type")
  sourceUrl         String?                @map("source_url")
  sourceTitle       String?                @map("source_title")
  author            String?
  isQuote           Boolean                @default(false) @map("is_quote")
  aiTrustLevel      AiTrustLevel?          @map("ai_trust_level")
  conversationId    String?                @map("conversation_id")
  parentInputId     String?                @map("parent_input_id")
  sourceSpan        Json?                  @map("source_span")

  // A-6: Evidence Character
  evidenceDomain    EvidenceDomain?        @map("evidence_domain")
  scope             Scope?

  // A-9: AI Analysis
  embedding         Unsupported("vector")?
  importance        Float                  @default(0)
  branchPotential   Float                  @default(0) @map("branch_potential")
  driftScore        Float                  @default(0) @map("drift_score")

  // A-10: Ordering
  sortOrder         Int?                   @map("sort_order")

  // A-11: User-defined
  energyLevel       EnergyLevel?           @map("energy_level")
  meta              Json?

  // Relations
  user              User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  project           Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assemblyItems     AssemblyItem[]
  relationsAsSource Relation[]             @relation("SourceUnit")
  relationsAsTarget Relation[]             @relation("TargetUnit")
  perspectives      UnitPerspective[]
  versions          UnitVersion[]
  resources         UnitResource[]
  unitContexts      UnitContext[]
  contextVisits     ContextVisit[]
  unitTags          UnitTag[]

  @@index([userId])
  @@index([projectId])
  @@index([lifecycle])
  @@index([unitType])
  @@index([createdAt])
  @@map("units")
}

model UnitPerspective {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  unitId     String     @map("unit_id") @db.Uuid
  contextId  String     @map("context_id") @db.Uuid
  type       UnitType?
  stance     Stance     @default(neutral)
  importance Float      @default(0.5)
  note       String?
  canvasX    Float?     @map("canvas_x")
  canvasY    Float?     @map("canvas_y")
  canvasZoom Float?     @map("canvas_zoom")
  relations  Relation[]
  context    Context    @relation(fields: [contextId], references: [id], onDelete: Cascade)
  unit       Unit       @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([unitId, contextId])
  @@index([contextId])
  @@map("unit_perspectives")
}

model Relation {
  id            String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sourceUnitId  String           @map("source_unit_id") @db.Uuid
  targetUnitId  String           @map("target_unit_id") @db.Uuid
  perspectiveId String?          @map("perspective_id") @db.Uuid
  type          String           @db.VarChar(50)
  strength      Float            @default(0.5)
  direction     String           @default("one_way") @db.VarChar(15)
  purpose       String[]         @default([])
  isCustom      Boolean          @default(false) @map("is_custom")
  customName    String?          @map("custom_name")
  isLoopback    Boolean          @default(false) @map("is_loopback")
  createdAt     DateTime         @default(now()) @map("created_at")
  perspective   UnitPerspective? @relation(fields: [perspectiveId], references: [id])
  sourceUnit    Unit             @relation("SourceUnit", fields: [sourceUnitId], references: [id], onDelete: Cascade)
  targetUnit    Unit             @relation("TargetUnit", fields: [targetUnitId], references: [id], onDelete: Cascade)

  @@index([sourceUnitId])
  @@index([targetUnitId])
  @@index([type])
  @@index([sourceUnitId, targetUnitId, type])
  @@map("relations")
}

model SystemRelationType {
  id          String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String @unique @db.VarChar(50)
  category    String @db.VarChar(50)
  description String
  sortOrder   Int    @map("sort_order")

  @@map("system_relation_types")
}

model CustomRelationType {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String   @default("")
  projectId   String   @map("project_id") @db.Uuid
  createdById String?  @map("created_by_id")
  scope       String   @default("private") @db.VarChar(10)
  reusable    Boolean  @default(false)
  purposeTag  String?  @map("purpose_tag")
  createdAt   DateTime @default(now()) @map("created_at")
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy   User?    @relation(fields: [createdById], references: [id])

  @@index([projectId])
  @@index([createdById])
  @@map("custom_relation_types")
}

model Context {
  id             String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  description    String?
  projectId      String            @map("project_id") @db.Uuid
  parentId       String?           @map("parent_id") @db.Uuid
  snapshot       String            @default("")
  openQuestions  Json              @default("[]") @map("open_questions")
  contradictions Json              @default("[]")
  sortOrder      Int               @default(0) @map("sort_order")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  parent         Context?          @relation("ContextHierarchy", fields: [parentId], references: [id])
  children       Context[]         @relation("ContextHierarchy")
  project        Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  navigators       Navigator[]
  perspectives     UnitPerspective[]
  unitContexts     UnitContext[]
  contextVisits    ContextVisit[]
  sourceReferences ContextReference[] @relation("SourceReferences")
  targetReferences ContextReference[] @relation("TargetReferences")
  reasoningChains  ReasoningChain[]

  @@unique([name, parentId, projectId])
  @@index([projectId])
  @@index([parentId])
  @@map("contexts")
}

model UnitContext {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  unitId     String   @map("unit_id") @db.Uuid
  contextId  String   @map("context_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at")
  unit       Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  context    Context  @relation(fields: [contextId], references: [id], onDelete: Cascade)

  @@unique([unitId, contextId])
  @@index([unitId])
  @@index([contextId])
  @@map("unit_contexts")
}

model ContextVisit {
  id               String   @id @default(cuid())
  userId           String   @map("user_id")
  contextId        String   @map("context_id") @db.Uuid
  lastVisitedAt    DateTime @default(now()) @map("last_visited_at")
  lastViewedUnitId String?  @map("last_viewed_unit_id") @db.Uuid
  updatedAt        DateTime @updatedAt @map("updated_at")
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  context          Context  @relation(fields: [contextId], references: [id], onDelete: Cascade)
  lastViewedUnit   Unit?    @relation(fields: [lastViewedUnitId], references: [id], onDelete: SetNull)

  @@unique([userId, contextId])
  @@index([userId])
  @@index([contextId])
  @@map("context_visits")
}

model UnitVersion {
  id              String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  unitId          String             @map("unit_id") @db.Uuid
  version         Int
  content         String
  meta            Json?
  changeReason    String?            @map("change_reason")
  diffSummary     String?            @map("diff_summary")
  /// How this version was produced (manual edit, AI suggestion, merge, split, or import)
  versionOrigin   VersionOriginType? @default(manual) @map("version_origin")
  /// Optional reference to the source range this version was derived from
  /// (e.g. character offsets within a source document, or a split-source unit ID)
  sourceSpan      String?            @map("source_span")
  createdAt       DateTime           @default(now()) @map("created_at")
  unit            Unit               @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([unitId, version])
  @@index([unitId])
  @@map("unit_versions")
}

model Assembly {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  projectId      String          @map("project_id") @db.Uuid
  templateType   String?         @map("template_type") @db.VarChar(50)
  sourceMap      Json?           @map("source_map")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items          AssemblyItem[]
  exportHistory  ExportHistory[]

  @@index([projectId])
  @@map("assemblies")
}

model AssemblyItem {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assemblyId String   @map("assembly_id") @db.Uuid
  unitId     String?  @map("unit_id") @db.Uuid
  position   Int
  bridgeText String?  @map("bridge_text")
  assembly   Assembly @relation(fields: [assemblyId], references: [id], onDelete: Cascade)
  unit       Unit?    @relation(fields: [unitId], references: [id])

  @@index([assemblyId])
  @@map("assembly_items")
}

model Navigator {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String?
  purpose     String?  @db.VarChar(30)
  contextId   String   @map("context_id") @db.Uuid
  path        String[] @default([]) @db.Uuid
  bridges     Json     @default("[]")
  context     Context  @relation(fields: [contextId], references: [id], onDelete: Cascade)

  @@index([contextId])
  @@map("navigators")
}

model ResourceUnit {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  resourceType ResourceType @map("resource_type")
  url          String
  fileName     String?      @map("file_name")
  mimeType     String?      @map("mime_type")
  fileSize     Int?         @map("file_size")
  metadata     Json?
  lifecycle    Lifecycle    @default(draft)
  userId       String       @map("user_id")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  units        UnitResource[]

  @@index([userId])
  @@index([resourceType])
  @@index([lifecycle])
  @@map("resource_units")
}

model UnitResource {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  unitId     String       @map("unit_id") @db.Uuid
  resourceId String       @map("resource_id") @db.Uuid
  role       String?      @db.VarChar(50)
  sortOrder  Int          @default(0) @map("sort_order")
  createdAt  DateTime     @default(now()) @map("created_at")
  unit       Unit         @relation(fields: [unitId], references: [id], onDelete: Cascade)
  resource   ResourceUnit @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([unitId, resourceId])
  @@index([unitId])
  @@index([resourceId])
  @@map("unit_resources")
}

// ─── Context Cross-References (Story 3.5) ─────────────────────────────

model ContextReference {
  id              String   @id @default(cuid())
  sourceContextId String   @map("source_context_id") @db.Uuid
  targetContextId String   @map("target_context_id") @db.Uuid
  description     String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  createdById     String   @map("created_by_id")

  sourceContext   Context  @relation("SourceReferences", fields: [sourceContextId], references: [id], onDelete: Cascade)
  targetContext   Context  @relation("TargetReferences", fields: [targetContextId], references: [id], onDelete: Cascade)
  createdBy       User     @relation(fields: [createdById], references: [id])

  @@unique([sourceContextId, targetContextId])
  @@index([sourceContextId])
  @@index([targetContextId])
  @@map("context_references")
}

// ─── Tags (Story 6.5) ─────────────────────────────────────────────────

model Tag {
  id        String    @id @default(cuid())
  name      String
  color     String?
  projectId String    @map("project_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  units     UnitTag[]

  @@unique([projectId, name])
  @@index([projectId])
  @@map("tags")
}

model UnitTag {
  unitId    String   @map("unit_id") @db.Uuid
  tagId     String   @map("tag_id")
  createdAt DateTime @default(now()) @map("created_at")
  unit      Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([unitId, tagId])
  @@index([unitId])
  @@index([tagId])
  @@map("unit_tags")
}

// ─── API Rate Limiting ────────────────────────────────────────────────

model RateLimitEntry {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id")
  endpoint  String   @db.VarChar(100)
  timestamp DateTime @default(now())

  @@index([userId, endpoint, timestamp])
  @@map("rate_limit_entries")
}

// ─── Safety Guard Session (AI rate-limiting) ─────────────────────────

model SafetyGuardSession {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                String   @map("user_id")
  consecutiveBranches   Int      @default(0) @map("consecutive_branches")
  createdAt             DateTime @default(now()) @map("created_at")
  lastActivityAt        DateTime @default(now()) @map("last_activity_at")

  @@index([userId])
  @@index([lastActivityAt])
  @@map("safety_guard_sessions")
}

// ─── Export History (Story 7.7) ──────────────────────────────────────

model ExportHistory {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assemblyId  String   @map("assembly_id") @db.Uuid
  assembly    Assembly @relation(fields: [assemblyId], references: [id], onDelete: Cascade)
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id])
  format      String   @db.VarChar(50)
  unitIds     String[] @map("unit_ids") @db.Uuid
  contentHash String   @map("content_hash") @db.VarChar(64)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([assemblyId])
  @@index([userId])
  @@map("export_history")
}


// ─── Reasoning Chains (Story 7.9) ─────────────────────────────────────

model ReasoningChain {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  goal      String?
  contextId String   @map("context_id") @db.Uuid
  context   Context  @relation(fields: [contextId], references: [id], onDelete: Cascade)
  steps     Json     // Array of { unitId: string, role: "premise"|"inference"|"conclusion", order: number }
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([contextId])
  @@map("reasoning_chains")
}

// ─── Webhooks (Story 10.2) ──────────────────────────────────────────

model Webhook {
  id        String   @id @default(cuid())
  url       String
  secret    String
  events    String[] @default([])
  active    Boolean  @default(true)
  projectId String   @map("project_id") @db.Uuid
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([userId])
  @@map("webhooks")
}
